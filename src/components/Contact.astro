<section id="contact" class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-heartwood-charcoal">
        Get a Quote
      </h2>
      <p class="mt-4 text-heartwood-stone text-lg max-w-2xl mx-auto">
        Ready to start your renovation? Tell us about your project and we'll get back to you promptly.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Contact Details -->
      <div>
        <h3 class="font-heading font-semibold text-2xl text-heartwood-charcoal mb-6">Contact Details</h3>

        <div class="space-y-6">
          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="text-heartwood-brown mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-heartwood-charcoal">Phone</p>
              <a href="tel:5192824445" class="text-heartwood-stone hover:text-heartwood-brown transition-colors">(519) 282-4445</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="text-heartwood-brown mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-heartwood-charcoal">Email</p>
              <!-- TODO: replace with actual email address -->
              <a href="mailto:info@heartwoodgc.com" class="text-heartwood-stone hover:text-heartwood-brown transition-colors">info@heartwoodgc.com</a>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <div class="text-heartwood-brown mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-heartwood-charcoal">Location</p>
              <p class="text-heartwood-stone">London, ON</p>
            </div>
          </div>

          <!-- Social -->
          <div class="flex items-start gap-4">
            <div class="text-heartwood-brown mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-heartwood-charcoal">Follow Us</p>
              <div class="flex gap-4 mt-1">
                <a href="https://www.facebook.com/heartwoodgc/" target="_blank" rel="noopener noreferrer" class="text-heartwood-stone hover:text-heartwood-brown transition-colors">Facebook</a>
                <a href="https://www.instagram.com/heartwoodgc/" target="_blank" rel="noopener noreferrer" class="text-heartwood-stone hover:text-heartwood-brown transition-colors">Instagram</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div>
        <!-- TODO: replace FORM_ID_HERE with your Formspree form ID -->
        <form action="https://formspree.io/f/FORM_ID_HERE" method="POST" class="space-y-5">
          <!-- Honeypot -->
          <div class="hidden" aria-hidden="true">
            <label for="_gotcha">Don't fill this out</label>
            <input type="text" name="_gotcha" id="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <div>
            <label for="name" class="block text-sm font-medium text-heartwood-charcoal mb-1">Name</label>
            <input
              type="text"
              name="name"
              id="name"
              required
              class="w-full px-4 py-3 rounded border border-heartwood-stone/30 bg-heartwood-cream/50 text-heartwood-charcoal focus:outline-none focus:ring-2 focus:ring-heartwood-brown/50 focus:border-heartwood-brown transition-colors"
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="phone" class="block text-sm font-medium text-heartwood-charcoal mb-1">Phone</label>
              <input
                type="tel"
                name="phone"
                id="phone"
                class="w-full px-4 py-3 rounded border border-heartwood-stone/30 bg-heartwood-cream/50 text-heartwood-charcoal focus:outline-none focus:ring-2 focus:ring-heartwood-brown/50 focus:border-heartwood-brown transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-heartwood-charcoal mb-1">Email</label>
              <input
                type="email"
                name="email"
                id="email"
                required
                class="w-full px-4 py-3 rounded border border-heartwood-stone/30 bg-heartwood-cream/50 text-heartwood-charcoal focus:outline-none focus:ring-2 focus:ring-heartwood-brown/50 focus:border-heartwood-brown transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="project-type" class="block text-sm font-medium text-heartwood-charcoal mb-1">Project Type</label>
              <select
                name="project-type"
                id="project-type"
                class="w-full px-4 py-3 rounded border border-heartwood-stone/30 bg-heartwood-cream/50 text-heartwood-charcoal focus:outline-none focus:ring-2 focus:ring-heartwood-brown/50 focus:border-heartwood-brown transition-colors"
              >
                <option value="">Select a type...</option>
                <option value="Kitchen">Kitchen</option>
                <option value="Bathroom">Bathroom</option>
                <option value="Basement">Basement</option>
                <option value="Outdoor Living">Outdoor Living</option>
                <option value="Flooring">Flooring</option>
                <option value="Tile Work">Tile Work</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label for="timeline" class="block text-sm font-medium text-heartwood-charcoal mb-1">Preferred Timeline</label>
              <select
                name="timeline"
                id="timeline"
                class="w-full px-4 py-3 rounded border border-heartwood-stone/30 bg-heartwood-cream/50 text-heartwood-charcoal focus:outline-none focus:ring-2 focus:ring-heartwood-brown/50 focus:border-heartwood-brown transition-colors"
              >
                <option value="">Select timeline...</option>
                <option value="ASAP">ASAP</option>
                <option value="1-3 months">1–3 months</option>
                <option value="3-6 months">3–6 months</option>
                <option value="Just exploring">Just exploring</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-heartwood-charcoal mb-1">Message</label>
            <textarea
              name="message"
              id="message"
              rows="4"
              class="w-full px-4 py-3 rounded border border-heartwood-stone/30 bg-heartwood-cream/50 text-heartwood-charcoal focus:outline-none focus:ring-2 focus:ring-heartwood-brown/50 focus:border-heartwood-brown transition-colors resize-y"
            ></textarea>
          </div>

          <!-- TODO: replace with your hCaptcha site key -->
          <!-- <div class="h-captcha" data-sitekey="YOUR_HCAPTCHA_SITE_KEY"></div> -->

          <button
            type="submit"
            class="w-full bg-heartwood-brown text-heartwood-cream py-4 rounded font-medium text-lg hover:bg-heartwood-tan transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
